# Copy this to .env.local (local dev), .env.dev, or .env.prod and fill in values.
# Non-secret defaults live in .env (committed). Only put secrets and overrides here.

# ── Required (no default) ──────────────────────────────────────────────────
BOT_DID=did:plc:yourbot
BOT_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SPACE_DIDS=did:plc:yourspace

# ── Override defaults from .env ────────────────────────────────────────────

# Local spaced infra stack (run: cd infra && pnpm setup):
# PDS_URL=http://localhost:2583
# LEAF_URL=http://localhost:5530
# LEAF_SERVER_DID=did:web:app.localhost
