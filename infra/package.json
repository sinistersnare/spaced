{
  "name": "@spaced/infra",
  "version": "0.1.0",
  "private": true,
  "description": "Docker Compose infrastructure for Spaced",
  "scripts": {
    "setup:network": "docker network create roomy-dev 2>/dev/null || true",
    "setup": "pnpm setup:network && bash scripts/setup-local.sh",
    "compose:build": "docker compose -f compose.yml build",
    "compose:up": "docker compose -f compose.yml up",
    "compose:down": "docker compose -f compose.yml down",
    "compose:prod:build": "docker compose -f compose.prod.yml build",
    "compose:prod:up": "docker compose -f compose.prod.yml up -d",
    "compose:prod:down": "docker compose -f compose.prod.yml down"
  }
}
