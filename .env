# Non-secret defaults — safe to commit.
# Override per environment in .env.local / .env.dev / .env.prod

# ATProto PDS the bot authenticates against
PDS_URL=https://bsky.social

# Leaf server (public dev instance)
LEAF_URL=https://leaf-dev.muni.town
# LEAF_SERVER_DID is auto-derived from LEAF_URL when not set

# Roomy stream NSIDs
STREAM_NSID=space.roomy.space.personal.dev
STREAM_HANDLE_NSID=space.roomy.space.handle.dev

# Admin API port
PORT=3401
