# ATProto account for the bot (app password, not main password)
BOT_DID=did:plc:yourbot
BOT_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Leaf server (defaults to the public dev instance)
LEAF_URL=https://leaf-dev.muni.town
LEAF_SERVER_DID=did:web:leaf-dev.muni.town

# ATProto record collection NSIDs (match your Roomy deployment)
STREAM_NSID=space.roomy.space.personal.dev
STREAM_HANDLE_NSID=space.roomy.space.handle.dev

# HTTP port for the admin API
PORT=3401
